{% extends "layout.njk" %}

{% set pageTitle = site.title %}
{% set pageDescription = site.description %}
{% set canonicalUrl = "" %}
{% set ogType = "website" %}

{% block content %}
  <!-- Loading state -->
  <div id="article-loading" class="space-y-8 animate-pulse">
    <div class="h-8 bg-slate-200 rounded-full w-3/4"></div>
    <div class="h-4 bg-slate-200 rounded-full w-1/2"></div>
    <div class="space-y-3">
      <div class="h-4 bg-slate-200 rounded-full"></div>
      <div class="h-4 bg-slate-200 rounded-full w-5/6"></div>
      <div class="h-4 bg-slate-200 rounded-full w-4/6"></div>
    </div>
  </div>

  <!-- Article content (hidden until loaded) -->
  <article id="article-content" class="space-y-12 hidden">

    <div id="article-image-container" class="-mx-6 lg:-mx-12 xl:-mx-16 mb-12 hidden">
      <div class="relative overflow-hidden rounded-3xl bg-slate-100">
        <img id="article-image" src="" alt="" class="w-full h-auto object-contain" />
      </div>
    </div>

    <header class="space-y-6 pb-12 border-b border-slate-200">
      <div class="space-y-4">
        <div class="flex items-center gap-4 text-sm font-medium text-slate-500">
          <time id="article-date" class="tracking-wide"></time>
          <span id="article-reading-time" class="flex items-center gap-1 hidden">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span id="article-reading-time-value"></span> min read
          </span>
        </div>
        <h1 id="article-title" class="text-4xl lg:text-5xl xl:text-6xl font-bold tracking-tight text-slate-900 leading-tight"></h1>
      </div>
      <div id="article-tags" class="flex flex-wrap gap-2"></div>
    </header>

    <div id="article-body" class="prose prose-lg xl:prose-xl max-w-none"></div>

  </article>

  <!-- Error state -->
  <div id="article-error" class="hidden text-center py-20 space-y-4">
    <p class="text-2xl font-bold text-slate-900">Articolo non trovato</p>
    <p class="text-slate-500">Impossibile caricare l'articolo richiesto.</p>
    <a href="{{ site.base_url }}/" class="inline-block mt-4 text-blue-600 hover:text-blue-700 font-medium">← Torna alla home</a>
  </div>
{% endblock %}
